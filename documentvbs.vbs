Function nwmsbhil(enc, key)
    Dim p, r, i, n, d1, d2
    p = Split(enc, ",")
    r = ""
    d1 = 0
    For i = 0 To UBound(p)
        n = CInt(Trim(p(i))) - key
        d2 = n
        r = r & Chr(d2)
    Next
    nwmsbhil = r
End Function

